diff --git a/Analysis/include/Luau/Module.h b/Analysis/include/Luau/Module.h
index df015f63..3058ba62 100644
--- a/Analysis/include/Luau/Module.h
+++ b/Analysis/include/Luau/Module.h
@@ -86,6 +86,14 @@ struct Module
     TypeArena interfaceTypes;
     TypeArena internalTypes;
 
+    // Our type graph can point into the interface types of the modules we
+    // require, so those modules must be kept alive for as long as we are.
+    // Without this, a stale module that can no longer be rechecked (e.g. its
+    // source file was renamed or deleted, so the frontend cannot re-enqueue
+    // it) dangles into freed arenas once a dependency is rechecked and
+    // replaced in the module resolver.
+    std::vector<ModulePtr> dependencyModules;
+
     // Scopes and AST types refer to parse data, so we need to keep that alive
     std::shared_ptr<Allocator> allocator;
     std::shared_ptr<AstNameTable> names;
diff --git a/Analysis/src/ConstraintGenerator.cpp b/Analysis/src/ConstraintGenerator.cpp
index ac5bf6f6..031f4a7f 100644
--- a/Analysis/src/ConstraintGenerator.cpp
+++ b/Analysis/src/ConstraintGenerator.cpp
@@ -1537,6 +1537,7 @@ ControlFlow ConstraintGenerator::visit(const ScopePtr& scope, AstStatLocal* stat
                 continue;
 
             const Name name{statLocal->vars.data[i]->name.value};
+            this->module->dependencyModules.push_back(module);
             scope->importedTypeBindings[name] = module->exportedTypeBindings;
             scope->importedModules[name] = moduleInfo->name;
 
